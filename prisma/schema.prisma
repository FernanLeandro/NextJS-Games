generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Console {
  id           Int      @id @default(autoincrement())
  name         String
  image        String   @default("no-image.png")
  releaseDate  DateTime
  manufacturer String
  description  String
  games        Game[]
}

model Game {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  cover       String   @default("no-cover.png")
  developer   String
  price       Float
  genre       String
  description String
  console_id  Int
  releaseDate DateTime
  console     Console  @relation(fields: [console_id], references: [id])
}
